= render 'application/breadcrumb', steps: [{ label: 'Audit Logs', path: audit_logs_path, icon: 'history' }, { label: "##{@audit.id}" }]

.d-flex.justify-content-between.align-items-center.mb-3
  %h2.fw-bold.text-dark.mb-0
    %span.mi.me-2 history
    Audit Entry ##{@audit.id}
  = link_to audit_logs_path, class: 'btn btn-link text-secondary text-decoration-none' do
    %span.mi.md-18 arrow_back
    Back to log

.row
  .col-md-5
    .card.shadow-sm.mb-4
      .card-body
        %h5.fw-bold.text-secondary.mb-3 Metadata
        %dl.row.mb-0
          %dt.col-sm-4 Time
          %dd.col-sm-8.font-monospace= @audit.created_at.strftime('%Y-%m-%d %H:%M:%S %Z')

          %dt.col-sm-4 User
          %dd.col-sm-8
            - if @audit.user
              = @audit.user.full_name.presence || @audit.user.login
              %span.text-muted.small= " (##{@audit.user.id})"
            - else
              %span.text-muted.fst-italic= @audit.actor_note.presence || 'system'

          %dt.col-sm-4 IP
          %dd.col-sm-8.font-monospace= @audit.ip_address.presence || '—'

          %dt.col-sm-4 Target
          %dd.col-sm-8.font-monospace= audit_target_label(@audit)

          %dt.col-sm-4 Action
          %dd.col-sm-8= audit_action_badge(@audit.action)

  .col-md-7
    .card.shadow-sm.mb-4
      .card-body
        %h5.fw-bold.text-secondary.mb-3 Changes
        = render 'diff', changes: @audit.object_changes
