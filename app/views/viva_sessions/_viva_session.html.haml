#viva-session{data: {controller: 'viva-session', 'viva-session-pending-value': pending_turn.to_s, 'viva-session-refresh-url-value': viva_refresh_submission_path(submission), 'viva-session-interval-ms-value': 3000}}
  .card.shadow-sm.mb-3
    .card-body{style: 'max-height: 70vh; overflow-y: auto;'}
      - turns.each do |turn|
        = render 'viva_sessions/turn', turn: turn

  -# Branch by submission status, not by viva_grade presence — viva_grade
  -# may exist but be partial (we save it before JSON parse to preserve
  -# llm_response_raw for diagnosis on failure).
  - case submission.status.to_s
  - when 'done'
    - if viva_grade
      = render partial: 'submissions/viva_grade', locals: {viva_grade: viva_grade, submission: submission}
    - else
      .alert.alert-warning Interview ended successfully but the grade record is missing. Contact an admin.
  - when 'grader_error'
    .alert.alert-danger
      %strong Grader error.
      = submission.grader_comment.to_s
      -# Editors see the raw response and a re-run button in the right-side
      -# Admin card; this branch stays text-only.
  - when 'evaluating'
    .alert.alert-info Interview ended. Grading in progress...

  - unless finished
    = render partial: 'viva_sessions/answer_form', locals: {submission: submission, pending_turn: pending_turn, finished: finished}
