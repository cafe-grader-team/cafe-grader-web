-# require *ds* as a dataset object
-#= turbo_frame_tag 'dataset_settings', data: {'problem-target': 'datasetSettings', 'base-url': settings_dataset_path(-123)} do
= simple_form_for ds, wrapper: :horizontal_form, multipart: true do |f|
  %div{'data-controller': 'init-ui-component'}
    %input{type: 'hidden', name: 'active_dataset_tab', value: @active_dataset_tab, data: {'bs-tab-target': 'activeTabInput'}}
    .row
      .col-12
        .d-flex.justify-content-between.align-items-center.mb-3.pb-2.border-bottom
          %h5.fw-bold.text-body-emphasis.mb-0 Basic Info
          = link_to audit_logs_path(auditable_type: 'Dataset', auditable_id: ds.id), class: 'btn btn-sm bg-white shadow-sm border-0 text-secondary d-inline-flex align-items-center justify-content-center', data: {bs_toggle: 'tooltip', bs_title: 'Change history (including testcases)'} do
            %span.mi history
        = f.input :name
        = f.input :time_limit, label: "Time limit (s)", tooltip: 'Decimals allowed (e.g., 1.2).'
        = f.input :memory_limit, label: "Memory limit (MB)"
        -# score_type — rich radio buttons (compilation_type pattern).
        -# 3 options each benefit from a short explanation; radios make
        -# the trade-offs scannable. See doc/dataset-scoring-and-evaluation.md.
        - score_options = [['<strong>Sum</strong> <span class="text-secondary">— weighted sum / total weight × 100. Default for most problems.</span>'.html_safe, 'sum'], ['<strong>Group Min</strong> <span class="text-secondary">— IOI/ICPC subtask style; a group is only as strong as its weakest testcase.</span>'.html_safe, 'group_min'], ['<strong>Raw Sum</strong> <span class="text-secondary">— literal Σ of testcase scores (no normalization). Pair with Custom CMS-raw evaluator.</span>'.html_safe, 'raw_sum']]
        = f.input :score_type, as: :radio_buttons, collection: score_options, wrapper: :horizontal_collection, tooltip: 'How testcase scores aggregate into a final grade.'

        -# evaluation_type — grouped select. 7 options would be too
        -# heavy as radios, but they cluster naturally into three groups.
        -# See doc/dataset-scoring-and-evaluation.md for full semantics.
        - eval_groups = [['Built-in', [['[DEFAULT] Diff — ignores whitespace differences and blank lines', 'default'], ['[EXACT] Diff — strict, no normalization', 'exact'], ['[RELATIVE] Token-by-token; numbers compared with 1e-6 tolerance', 'relative']]], ['Custom checker', [['[CAFE] CORRECT/INCORRECT/COMMENT + score (cafe protocol)', 'custom_cafe'], ['[CMS] CMS/Codeforces protocol (score on stdout)', 'custom_cms'], ['[CMS-raw] Raw checker output — pair with Raw Sum score type', 'custom_cms_raw']]], ['Special', [['[POSTGRES] SQL query result; strips CREATE/DROP VIEW lines', 'postgres']]]]
        = f.input :evaluation_type, as: :grouped_select, collection: eval_groups, group_method: :last, group_label_method: :first, label_method: :first, value_method: :last, include_blank: false, wrapper: :horizontal_select, input_html: {data: {'dataset-mode-toggle-target': 'evaluationType'}}, tooltip: 'How submission output is judged against the expected answer.'
        -# Until managers exist there's nothing to pick, so show a
        -# disabled placeholder pointing the user at the upload form
        -# in the Files tab. Mirrors initializer_filename below.
        = f.input :main_filename, collection: ds.managers.joins(:blob).pluck(:filename), include_blank: '-- Upload a manager file first --', wrapper: :horizontal_select, disabled: ds.managers.blank?, wrapper_html: {data: {'dataset-mode-toggle-target': 'hideForSelfContained'}}
        = f.input :initializer_filename, collection: ds.initializers.joins(:blob).pluck(:filename), include_blank: '-- No initializers --', wrapper: :horizontal_select, disabled: ds.initializers.blank?
        = f.button :submit, class: 'btn-primary'
