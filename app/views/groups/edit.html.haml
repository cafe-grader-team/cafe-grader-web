= render 'application/breadcrumb', steps: [{ label: 'Groups', path: groups_path, icon: 'group' }, { label: 'Edit' }]

.d-flex.justify-content-between.align-items-center.mb-3
  .d-flex.align-items-center.gap-2
    %h2.fw-bold.text-dark.mb-0= @group.name
    %span.badge.bg-primary-subtle.text-primary.border.border-primary-subtle.rounded-pill.fw-medium
      %small Editing

  .d-flex.gap-2
    = link_to 'Cancel', group_path(@group), class: 'btn btn-link text-secondary text-decoration-none'
    %button.btn.btn-primary.px-4.shadow-sm{type: 'submit', form: 'edit_group_form'} Save Changes

.row
  .col-md-5
    .card.shadow-sm.mb-4
      .card-body
        %h5.fw-bold.text-secondary.mb-3 Basic Info
        = simple_form_for @group, url: group_path(@group), wrapper: :horizontal_form, html: { id: 'edit_group_form' } do |f|
          = render partial: 'form', locals: { f: f }
  .col-md-7
    .card.shadow-sm.mb-4
      .card-body
        %h5.fw-bold.text-secondary.mb-3 Group Overview
        .row.text-center.mb-4
          .col-6
            .p-3.bg-light.rounded
              %h3.fw-bold.text-primary.mb-1= @group.users.count
              %p.text-muted.small.mb-0 Users
          .col-6
            .p-3.bg-light.rounded
              %h3.fw-bold.text-primary.mb-1= @group.problems.count
              %p.text-muted.small.mb-0 Problems
        
        .alert.alert-info.d-flex.align-items-center.mb-0.border-0.bg-info-subtle.text-info-emphasis
          %span.mi.md-24.me-3 info
          %div
            %strong.d-block Resource Management
            %span.small Manage specific user roles and toggle available problems interactively on the 
            = link_to 'Group Details', group_path(@group), class: 'fw-bold text-decoration-none'
            %span.small page.
