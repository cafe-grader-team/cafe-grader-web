= simple_form_for :null, url: manage_problem_hint_index_path(@problem), wrapper: :inline_form, html: { class: 'mb-3', data: { controller: 'init-ui-component', turbo: 'true', 'children-select-target': 'selectForm' } } do |f|
  .d-flex.flex-wrap.align-items-center.gap-2
    = f.input :hint_id, label: false, collection: @problem.hints, selected: @hint&.id, wrapper: :inline_form, include_blank: '— Select hint —',
      input_html: {class: 'select2', style: 'min-width: 14rem;', data: {action: 'change->children-select#childSelect', 'children-select-target': 'selectInput'}}
    %button.btn.btn-success.btn-sm.d-inline-flex.align-items-center.gap-1{type: :submit, name: :button, value: :add}
      %span.mi.md-18 add
      Add hint
    -# Push Delete to the trailing edge so it's not adjacent to Add (reduces slip-click risk).
    %button.btn.btn-outline-danger.btn-sm.d-inline-flex.align-items-center.gap-1.ms-auto{type: :submit, name: :button, value: :delete, data: { turbo_confirm: "Delete this hint? This cannot be undone." }}
      %span.mi.md-18 delete
      Delete
