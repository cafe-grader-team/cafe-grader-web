= render 'application/breadcrumb', steps: [{ label: 'Problems', path: problems_path, icon: resource_icon_name(Problem) }, { label: 'Import', path: import_problems_path }, { label: 'Result' }]

.d-flex.align-items-center.gap-2.mb-4
  %h2.fw-bold.text-dark.mb-0 Import Complete
  %span.badge.bg-success-subtle.text-success.border.border-success-subtle.rounded-pill.fw-medium
    %small= mdi(:check, 'md-16 me-1')
    Success

.card.shadow-sm.mb-4
  .card-body
    .d-flex.align-items-center.gap-3.mb-3
      .bg-primary-subtle.text-primary-emphasis.rounded-circle.d-flex.align-items-center.justify-content-center.lh-1{style: "width: 48px; height: 48px"}
        %span.mi.md-24 quiz
      %div
        %h5.fw-bold.text-dark.mb-0= @problem.full_name
        %small.text-secondary.font-monospace= @problem.name

    .d-flex.flex-wrap.gap-2
      = link_to edit_problem_path(@problem), class: 'btn btn-sm btn-primary d-inline-flex align-items-center gap-1' do
        = mdi(:edit, 'md-16')
        Edit Problem
      = link_to import_problems_path, class: 'btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1' do
        = mdi(:upload_file, 'md-16')
        Import Another
      = link_to problems_path, class: 'btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1' do
        = mdi(:list, 'md-16')
        Problem List

.card.shadow-sm.mb-4
  .card-body
    %h5.fw-bold.text-secondary.mb-3
      = mdi(:receipt_long, 'me-1')
      Import Log
    %pre.import-log.bg-light.rounded.p-3.mb-0.small
      = @log.join("\n")
