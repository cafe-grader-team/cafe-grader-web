= render 'application/breadcrumb', steps: [{ label: 'Problems', path: problems_path, icon: resource_icon_name(Problem) }, { label: 'Edit' }]

.d-flex.justify-content-between.align-items-center.mb-3
  .d-flex.align-items-center.gap-2
    %h2.fw-bold.text-dark.mb-0
      - if @problem.full_name.present?
        = @problem.full_name
      - else
        %span.text-muted.fst-italic [Untitled Problem ##{@problem.id}]
      %span.font-monospace.text-secondary.fw-normal= "[#{@problem.name}]"
    %span.badge.bg-primary-subtle.text-primary.border.border-primary-subtle.rounded-pill.fw-medium
      %small Editing

  .d-flex.gap-2.align-items-center{'data-controller': 'init-ui-component'}
    = link_to stat_problem_path(@problem), class: 'btn btn-sm bg-white shadow-sm border-0 text-secondary d-inline-flex align-items-center justify-content-center', data: {bs_toggle: 'tooltip', bs_title: 'Statistics'} do
      %span.mi query_stats
    = link_to download_archive_problem_path(@problem), class: 'btn btn-sm bg-white shadow-sm border-0 text-secondary d-inline-flex align-items-center justify-content-center', data: {bs_toggle: 'tooltip', bs_title: 'Download Archive'} do
      %span.mi download
    = link_to audit_logs_path(auditable_type: 'Problem', auditable_id: @problem.id), class: 'btn btn-sm bg-white shadow-sm border-0 text-secondary d-inline-flex align-items-center justify-content-center', data: {bs_toggle: 'tooltip', bs_title: 'Change history'} do
      %span.mi history
    %button.btn.btn-sm.bg-white.shadow-sm.border-0.text-secondary.d-inline-flex.align-items-center.gap-1{type: 'button', data: {bs_toggle: 'offcanvas', bs_target: '#problem-edit-help', bs_title: 'Help'}}
      %span.mi help_outline
      Help
    .vr.mx-1
    = link_to 'Cancel', problems_path, class: 'btn btn-link text-secondary text-decoration-none'

.row
  -# problem card
  .col-md-6
    .card.shadow-sm.mb-4
      .card-body
        %h5.fw-bold.text-secondary.mb-3 Detail
        = render 'form', problem: @problem
  -# dataset card
  .col-md-6
    .card.shadow-sm.mb-4
      .card-body{data: {controller: 'bs-tab dataset-mode-toggle', 'dataset-mode-toggle-compilation-type-value': @problem.compilation_type, action: 'mode:compilation-type-changed@window->dataset-mode-toggle#syncCompilationType'}}
        - if @problem.viva_exam?
          %h5.fw-bold.text-body-emphasis.mb-3.pb-2.border-bottom Viva Exam
          %p.text-secondary
            This problem is a Viva Exam. Interview flow is driven by
            %code llm_prompt
            tags (interviewer persona + rubric) and
            %code viva_grounding
            tags (course materials), attached in the tags picker on the left. Test-case datasets do not apply.
        - else
          %h5.fw-bold.text-body-emphasis.mb-3.pb-2.border-bottom Datasets
          -# dataset selector
          = turbo_frame_tag :dataset_select do
            = render partial: 'datasets/dataset_select', locals: {ds: @problem.live_dataset, problem: @problem}
          -# dataset form
          - if @problem.live_dataset
            = turbo_frame_tag :dataset, src: edit_dataset_path(@problem.live_dataset), data: {'problem-target': 'dataset', 'current-id': @problem.live_dataset.id}

-# Offcanvas help drawer (kept outside .row so it overlays the page on the right)
= render 'edit_help'
