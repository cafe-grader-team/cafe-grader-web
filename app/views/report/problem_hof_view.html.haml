= render 'application/breadcrumb', steps: [{ label: 'Hall of Fame', path: problem_hof_report_path }, { label: @problem.full_name }]
.d-flex.justify-content-between.align-items-center.mb-4{data: {controller: 'init-ui-component'}}
  .d-flex.align-items-center.gap-2
    %h2.fw-bold.text-dark.mb-0
      %span.font-monospace.text-secondary [#{@problem.name}]
      = @problem.full_name
  - if @current_user.can_edit_problem?(@problem)
    .d-flex.gap-1
      = link_to edit_problem_path(@problem), class: 'btn btn-sm bg-white shadow-sm border-0 text-secondary d-inline-flex align-items-center justify-content-center', data: {bs_toggle: 'tooltip', bs_title: 'Edit problem'} do
        %span.mi edit
      = link_to stat_problem_path(@problem), class: 'btn btn-sm bg-white shadow-sm border-0 text-secondary d-inline-flex align-items-center justify-content-center', data: {bs_toggle: 'tooltip', bs_title: 'Statistics'} do
        %span.mi query_stats
= render partial: 'task_hof'
