# LLM configuration. The shared `llm_services` anchor below is merged into
# every environment block; that's how the keys actually get loaded by
# `Rails.application.config_for(:llm)`. Keys placed at the top level (outside
# the anchor) are ignored.
#
# Two kinds of keys live in the anchor:
#
# 1) Per-model service registrations — `<ClassName>: <comma-separated models>`.
#    The cafe_grader initializer reads these and builds
#    Rails.configuration.llm[:provider] so that lookups like
#    `provider["gemini-2.5-pro"].constantize` resolve to `Llm::GenieAssist`.
#    See config/initializers/cafe_grader.rb.
#
# 2) Direct viva-service overrides — `viva_turn_service` / `viva_grade_service`.
#    These name a concrete subclass of Llm::VivaTurnAssist / Llm::VivaGradeAssist
#    that the matching job will instantiate. Leave blank to have the abstract
#    bases raise NotImplementedError at call time (intentional default — viva
#    exams won't work until a concrete subclass is configured).
#
# To use: copy this file to config/llm.yml and fill in values for your
# installation.

llm_services: &services
  # Per-model service registrations. Examples (uncomment + adjust as needed):
  # ChatGPTAssist: ChatGPT-4o,ChatGPT-o3
  # GenieAssist:   gemini-2.5-pro,Claude-Sonnet

  # Direct viva-service overrides. Leave blank if not using viva exams.
  viva_turn_service:
  viva_grade_service:

development:
  <<: *services

production:
  <<: *services

test:
  <<: *services
