# change this to your setting
user_pass: &user_pass
  username: grader
  password: grader

default: &default
  adapter: mysql2
  encoding: utf8mb4
  # canonical collation — MySQL 8 only, MariaDB unsupported (doc/decisions.md)
  collation: utf8mb4_0900_ai_ci
  pool: <%= ENV.fetch("RAILS_MAX_THREADS") { 5 } %>
  host: localhost
  socket: /var/run/mysqld/mysqld.sock

test:
  primary:
    <<: [*user_pass]
    adapter: mysql2
    database: grader_test
  queue:
    <<: [*user_pass]
    adapter: mysql2
    database: grader_queue_test
    migrations_paths: db/queue_migrate

production:
  primary:
    <<: [*user_pass, *default]
    database: grader
  queue:
    <<: [*user_pass, *default]
    database: grader_queue
    migrations_paths: db/queue_migrate

development:
  primary:
    <<: [*user_pass, *default]
    database: grader
  queue:
    <<: [*user_pass, *default]
    database: grader_queue
    migrations_paths: db/queue_migrate
